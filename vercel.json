{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "index.html",
          "admin.html",
          "app.js",
          "styles.css",
          "questions.txt",
          "scores.json",
          "robots.txt",
          "sitemap.xml",
          "*.png",
          "*.jpg"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "server.js" }
  ]
}
